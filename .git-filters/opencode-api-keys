#!/bin/bash
# OpenCode API Key filter for git
# Usage:
#   clean: stdin -> stdout (strip password for commit)
#   smudge: stdin -> stdout (restore password from local file)

source .env

MODE="$1"
PLACEHOLDER="CHANGEME"

case "$MODE" in
  clean)
    # Read JSON from stdin, replace password with placeholder
    # We use sed to handle the password line
    sed 's/"CONTEXT7_API_KEY":\s*"[^"]*"/"CONTEXT7_API_KEY": "'"$PLACEHOLDER"'"/'
    ;;
  smudge)

    # Read JSON from stdin
    CONTENT=$(cat)

    # If we have a real password, use it; otherwise keep placeholder
    if [[ -n "$CONTEXT7_API_KEY" && "$CONTEXT7_API_KEY" != "$PLACEHOLDER" ]]; then
      echo "$CONTENT" | sed 's/"CONTEXT7_API_KEY":\s*"[^"]*"/"CONTEXT7_API_KEY": "'"$CONTEXT7_API_KEY"'"/'
    else
      echo "$CONTENT"
    fi
    ;;
  *)
    echo "Usage: $0 {clean|smudge}" >&2
    exit 1
    ;;
esac
