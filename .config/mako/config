background-color=#1e1e2e
text-color=#cdd6f4
border-color=#cba6f7
border-size=2
border-radius=5
padding=10
margin=10
width=400
height=150

default-timeout=5000
ignore-timeout=1
max-visible=3
layer=overlay
anchor=top-right
font=JetBrainsMono Nerd Font 12

[urgency=low]
border-color=#585b70
default-timeout=3000

[urgency=normal]
border-color=#cba6f7
default-timeout=5000

[urgency=high]
border-color=#f38ba8
text-color=#f38ba8
default-timeout=0

[urgency=critical]
border-color=#f38ba8
text-color=#f38ba8
default-timeout=0

[app-name=volume]
default-timeout=2000
group-by=app-name

[app-name=brightness]
default-timeout=2000
group-by=app-name
