[pull]
	rebase = true
[user]
	email = personal@lukeh.us
	name = BlackHat-Magic
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[include]
	path = ~/.config/delta/catppuccin.gitconfig
[merge]
	conflictStyle = zdiff3
[diff]
	external = difft
[delta]
	dark = true
[filter "opencode-api-keys"]
	clean = .git-filters/opencode-api-keys clean
	smudge = .git-filters/opencode-api-keys smudge
[filter "obs-websocket"]
	clean = .git-filters/obs-websocket-filter clean
	smudge = .git-filters/obs-websocket-filter smudge
